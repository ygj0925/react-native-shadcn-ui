{
  "name": "react-native-shadcn-ui",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "dotenv -e .env.development -- expo start -c --host lan",
    "dev:staging": "dotenv -e .env.staging -- expo start -c --host lan",
    "dev:prod": "dotenv -e .env.production -- expo start -c --host lan",
    "android": "dotenv -e .env.development -- expo start -c --android",
    "ios": "dotenv -e .env.development -- expo start -c --ios",
    "web": "dotenv -e .env.development -- expo start -c --web",
    "build:android:dev": "dotenv -e .env.development -- npx eas build --platform android --profile development",
    "build:ios:dev": "dotenv -e .env.development -- npx eas build --platform ios --profile development",
    "build:ios:simulator": "dotenv -e .env.development -- npx eas build --platform ios --profile ios-simulator",
    "build:android:preview": "dotenv -e .env.staging -- npx eas build --platform android --profile preview",
    "build:ios:preview": "dotenv -e .env.staging -- npx eas build --platform ios --profile preview",
    "build:android:prod": "dotenv -e .env.production -- npx eas build --platform android --profile production",
    "build:ios:prod": "dotenv -e .env.production -- npx eas build --platform ios --profile production",
    "clean": "rm -rf .expo node_modules"
  },
  "dependencies": {
