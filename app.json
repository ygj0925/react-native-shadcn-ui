{
  "expo": {
    "name": "react-native-shadcn-ui",
    "slug": "react-native-shadcn-ui",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "react-native-shadcn-ui",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "y",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "edgeToEdgeEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ],
      "package": "com.yuanguangji.reactnativeshadcnui"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "resizeMode": "contain",
          "backgroundColor": "#232323",
          "image": "./assets/images/react-native-reusables-light.png",
          "dark": {
            "image": "./assets/images/react-native-reusables-dark.png",
            "backgroundColor": "#000000"
          },
          "imageWidth": 150
        }
      ],
      "react-native-localize",
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow calendar access to sync and manage scheduled events."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5bcca772-e4c6-4648-9853-a26ba6cdfa02"
      }
    },
    "owner": "yuanguangji"
  }
}